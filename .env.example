# Neon serverless Postgres connection string (Project → Connection Details).
# Use the pooled connection string and keep sslmode=require.
DATABASE_URL=""

# Secret used to sign the session-id cookie (JWT). Generate with:
#   openssl rand -base64 32
SESSION_SECRET=""

# Cloudinary (Dashboard → Product Environment Credentials).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Used only by scripts/create-admin.ts to seed the first user.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""

# Optional. Lifts the GitHub API rate limit (60 -> 5000 req/hr) for the live
# org stats on the About page. A fine-grained token with public read access is
# enough; the site works without it.
GITHUB_TOKEN=""
