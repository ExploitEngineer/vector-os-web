CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Used only by scripts/create-admin.ts to seed the first user.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""
